---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="{{PROJECT_NAME}} — {{PROJECT_ONE_LINER}}"
	description="{{PROJECT_NAME}}. {{PROJECT_ONE_LINER}}.{{#PHONE}} Бронь: {{PHONE}}.{{/PHONE}}"
>
	<div class="min-h-screen">

		<!-- ═══ HEADER ═══ -->
		<header class="sticky top-0 z-50 border-b border-base-content/20 bg-base-100/95 backdrop-blur px-4 md:px-8">
			<div class="mx-auto flex h-14 w-full max-w-6xl items-center justify-between">
				<a href="/" class="font-mono text-sm font-semibold uppercase tracking-widest text-primary">{{PROJECT_NAME}}</a>
				<nav class="hidden md:flex items-center gap-6 text-sm">
					<a href="#about" class="hover:text-primary transition-colors">О нас</a>
					<a href="#services" class="hover:text-primary transition-colors">Услуги</a>
					<a href="#reviews" class="hover:text-primary transition-colors">Отзывы</a>
					<a href="#faq" class="hover:text-primary transition-colors">FAQ</a>
				</nav>
				<a href="#booking" class="btn btn-primary btn-sm">Связаться</a>
			</div>
		</header>

		<main>

			<!-- ═══ 1. HERO ═══ -->
			<section class="border-b border-base-content/20 bg-base-100 px-4 py-16 md:px-8 md:py-24">
				<div class="mx-auto max-w-6xl">
					<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-4">
						[ГОРОД / АДРЕС]
					</p>
					<div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
						<div class="space-y-6">
							<h1 class="font-display text-5xl leading-[1.05] md:text-7xl font-bold">
								{{PROJECT_NAME}} — {{PROJECT_ONE_LINER}}
							</h1>
							<p class="text-base-content/70 text-lg leading-relaxed">
								[ЗАПОЛНИТЬ: 1-2 предложения — главное о проекте]
							</p>
							<p class="font-mono text-xs uppercase tracking-widest text-base-content/50">
								[КЛЮЧЕВАЯ ФИШКА]
							</p>
							<div class="flex flex-wrap gap-3 pt-2">
								<a href="#booking" class="btn btn-primary">Оставить заявку</a>
								<a href="#services" class="btn btn-outline border-base-content/30 text-base-content hover:bg-base-200">Подробнее</a>
							</div>
						</div>
						<div class="border border-base-content/20 bg-base-200 p-6 md:p-8">
							<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-4">ПОЧЕМУ МЫ</p>
							<ul class="space-y-3">
								<li class="flex gap-3">
									<span class="text-primary font-bold mt-0.5">—</span>
									<span>[ПРЕИМУЩЕСТВО 1]</span>
								</li>
								<li class="flex gap-3">
									<span class="text-primary font-bold mt-0.5">—</span>
									<span>[ПРЕИМУЩЕСТВО 2]</span>
								</li>
								<li class="flex gap-3">
									<span class="text-primary font-bold mt-0.5">—</span>
									<span>[ПРЕИМУЩЕСТВО 3]</span>
								</li>
								<li class="flex gap-3">
									<span class="text-primary font-bold mt-0.5">—</span>
									<span>[ПРЕИМУЩЕСТВО 4]</span>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<!-- ═══ 2. О НАС ═══ -->
			<section id="about" class="border-b border-base-content/20 bg-base-200 px-4 py-16 md:px-8 md:py-20">
				<div class="mx-auto max-w-6xl space-y-8">
					<div>
						<h2 class="font-display text-4xl leading-[1.1] md:text-5xl font-bold">О нас</h2>
						<p class="mt-3 text-base-content/70">
							[ЗАПОЛНИТЬ: 1 предложение о проекте]
						</p>
					</div>
					<div class="grid gap-4 md:grid-cols-3">
						<article class="border border-base-content/20 bg-base-100 p-6">
							<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-3">01 / FEATURE</p>
							<h3 class="font-display text-2xl mb-3">[Заголовок]</h3>
							<p class="text-base-content/70 text-sm leading-relaxed">
								[Описание фишки/преимущества]
							</p>
						</article>
						<article class="border border-base-content/20 bg-base-100 p-6">
							<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-3">02 / FEATURE</p>
							<h3 class="font-display text-2xl mb-3">[Заголовок]</h3>
							<p class="text-base-content/70 text-sm leading-relaxed">
								[Описание фишки/преимущества]
							</p>
						</article>
						<article class="border border-base-content/20 bg-base-100 p-6">
							<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-3">03 / FEATURE</p>
							<h3 class="font-display text-2xl mb-3">[Заголовок]</h3>
							<p class="text-base-content/70 text-sm leading-relaxed">
								[Описание фишки/преимущества]
							</p>
						</article>
					</div>
				</div>
			</section>

			<!-- ═══ 3. УСЛУГИ / МЕНЮ ═══ -->
			<section id="services" class="border-b border-base-content/20 bg-base-100 px-4 py-16 md:px-8 md:py-20">
				<div class="mx-auto max-w-6xl space-y-8">
					<div>
						<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-2">[SERVICES]</p>
						<h2 class="font-display text-4xl leading-[1.1] md:text-5xl font-bold">Услуги</h2>
						<p class="mt-3 max-w-2xl text-base-content/70">
							[ЗАПОЛНИТЬ: описание услуг / меню]
						</p>
					</div>
					<div class="grid gap-4 md:grid-cols-3">
						<div class="border border-base-content/20 bg-base-200 p-5">
							<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-2">КАТЕГОРИЯ</p>
							<div class="space-y-2 mt-3">
								<div class="flex justify-between text-sm">
									<span>[Пункт 1]</span>
									<span class="text-primary font-semibold ml-2">[Цена]</span>
								</div>
								<div class="flex justify-between text-sm">
									<span>[Пункт 2]</span>
									<span class="text-primary font-semibold ml-2">[Цена]</span>
								</div>
								<div class="flex justify-between text-sm">
									<span>[Пункт 3]</span>
									<span class="text-primary font-semibold ml-2">[Цена]</span>
								</div>
							</div>
						</div>
						<div class="border border-base-content/20 bg-base-200 p-5">
							<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-2">КАТЕГОРИЯ</p>
							<div class="space-y-2 mt-3">
								<div class="flex justify-between text-sm">
									<span>[Пункт 1]</span>
									<span class="text-primary font-semibold ml-2">[Цена]</span>
								</div>
							</div>
						</div>
						<div class="border border-base-content/20 bg-base-200 p-5">
							<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-2">КАТЕГОРИЯ</p>
							<div class="space-y-2 mt-3">
								<div class="flex justify-between text-sm">
									<span>[Пункт 1]</span>
									<span class="text-primary font-semibold ml-2">[Цена]</span>
								</div>
							</div>
						</div>
					</div>
					<p class="text-base-content/50 text-sm">* Информация о ценах не является публичной офертой.</p>
				</div>
			</section>

			<!-- ═══ 4. КЛЮЧЕВАЯ ФИШКА ═══ -->
			<section id="feature" class="border-b border-base-content/20 bg-base-200 px-4 py-16 md:px-8 md:py-20">
				<div class="mx-auto max-w-6xl space-y-8">
					<div>
						<h2 class="font-display text-4xl leading-[1.1] md:text-5xl font-bold">[Ключевая фишка]</h2>
						<p class="mt-3 max-w-2xl text-base-content/70">
							[ЗАПОЛНИТЬ: описание главного преимущества]
						</p>
					</div>
					<div class="grid gap-4 md:grid-cols-4">
						<article class="border border-base-content/20 bg-base-100 p-5 text-center">
							<p class="font-display text-4xl font-bold text-primary mb-2">[N]</p>
							<p class="text-sm text-base-content/70">[Описание]</p>
						</article>
						<article class="border border-base-content/20 bg-base-100 p-5 text-center">
							<p class="font-display text-4xl font-bold text-primary mb-2">[N]</p>
							<p class="text-sm text-base-content/70">[Описание]</p>
						</article>
						<article class="border border-base-content/20 bg-base-100 p-5 text-center">
							<p class="font-display text-4xl font-bold text-primary mb-2">[N]</p>
							<p class="text-sm text-base-content/70">[Описание]</p>
						</article>
						<article class="border border-base-content/20 bg-base-100 p-5 text-center">
							<p class="font-display text-4xl font-bold text-primary mb-2">[N]</p>
							<p class="text-sm text-base-content/70">[Описание]</p>
						</article>
					</div>
				</div>
			</section>

			<!-- ═══ 5. ОТЗЫВЫ ═══ -->
			<section id="reviews" class="border-b border-base-content/20 bg-base-100 px-4 py-16 md:px-8 md:py-20">
				<div class="mx-auto max-w-6xl space-y-8">
					<div>
						<h2 class="font-display text-4xl leading-[1.1] md:text-5xl font-bold">Отзывы</h2>
						<p class="mt-3 text-base-content/70">
							[ЗАПОЛНИТЬ: вступление к отзывам]
						</p>
					</div>
					<div class="grid gap-4 md:grid-cols-3">
						<blockquote class="border border-base-content/20 bg-base-200 p-5">
							<p class="text-sm text-base-content/70 leading-relaxed italic mb-3">«[Текст отзыва 1]»</p>
							<footer class="font-mono text-xs text-base-content/50">— [Имя], [Источник]</footer>
						</blockquote>
						<blockquote class="border border-base-content/20 bg-base-200 p-5">
							<p class="text-sm text-base-content/70 leading-relaxed italic mb-3">«[Текст отзыва 2]»</p>
							<footer class="font-mono text-xs text-base-content/50">— [Имя], [Источник]</footer>
						</blockquote>
						<blockquote class="border border-base-content/20 bg-base-200 p-5">
							<p class="text-sm text-base-content/70 leading-relaxed italic mb-3">«[Текст отзыва 3]»</p>
							<footer class="font-mono text-xs text-base-content/50">— [Имя], [Источник]</footer>
						</blockquote>
					</div>
				</div>
			</section>

			<!-- ═══ 6. FAQ ═══ -->
			<section id="faq" class="border-b border-base-content/20 bg-base-200 px-4 py-16 md:px-8 md:py-20">
				<div class="mx-auto max-w-6xl space-y-8">
					<div>
						<h2 class="font-display text-4xl leading-[1.1] md:text-5xl font-bold">Часто спрашивают</h2>
					</div>
					<div class="grid gap-3 md:grid-cols-2">
						<div class="border border-base-content/20 bg-base-100 p-5 collapse collapse-arrow">
							<input type="checkbox" />
							<div class="collapse-title font-semibold pr-8">[Вопрос 1]</div>
							<div class="collapse-content text-sm text-base-content/70">
								[Ответ 1]
							</div>
						</div>
						<div class="border border-base-content/20 bg-base-100 p-5 collapse collapse-arrow">
							<input type="checkbox" />
							<div class="collapse-title font-semibold pr-8">[Вопрос 2]</div>
							<div class="collapse-content text-sm text-base-content/70">
								[Ответ 2]
							</div>
						</div>
						<div class="border border-base-content/20 bg-base-100 p-5 collapse collapse-arrow">
							<input type="checkbox" />
							<div class="collapse-title font-semibold pr-8">[Вопрос 3]</div>
							<div class="collapse-content text-sm text-base-content/70">
								[Ответ 3]
							</div>
						</div>
						<div class="border border-base-content/20 bg-base-100 p-5 collapse collapse-arrow">
							<input type="checkbox" />
							<div class="collapse-title font-semibold pr-8">[Вопрос 4]</div>
							<div class="collapse-content text-sm text-base-content/70">
								[Ответ 4]
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ═══ 7. ГАЛЕРЕЯ ═══ -->
			<section id="gallery" class="border-b border-base-content/20 bg-base-100 px-4 py-16 md:px-8 md:py-20">
				<div class="mx-auto max-w-6xl space-y-8">
					<div>
						<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-2">Галерея</p>
						<h2 class="font-display text-4xl leading-[1.1] md:text-5xl font-bold">[Заголовок галереи]</h2>
						<p class="mt-3 max-w-2xl text-base-content/70">
							[ЗАПОЛНИТЬ: описание галереи]
						</p>
					</div>
					<div class="grid gap-4 md:grid-cols-3">
						<figure class="border border-base-content/20 bg-base-200 overflow-hidden">
							<!-- Замени src на путь к фото: /имя-файла.jpg -->
							<!-- Фото класть в public/: docs/prototypes/<slug>/public/ -->
							<!-- Astro раздаёт public/ как статику, путь от корня -->
							<div class="aspect-[4/3] bg-base-300 flex items-center justify-center">
								<p class="font-mono text-xs text-base-content/40 tracking-widest uppercase">[ФОТО 1]</p>
							</div>
							<figcaption class="p-3 text-sm text-base-content/60">[Подпись к фото]</figcaption>
						</figure>
						<figure class="border border-base-content/20 bg-base-200 overflow-hidden">
							<div class="aspect-[4/3] bg-base-300 flex items-center justify-center">
								<p class="font-mono text-xs text-base-content/40 tracking-widest uppercase">[ФОТО 2]</p>
							</div>
							<figcaption class="p-3 text-sm text-base-content/60">[Подпись к фото]</figcaption>
						</figure>
						<figure class="border border-base-content/20 bg-base-200 overflow-hidden">
							<div class="aspect-[4/3] bg-base-300 flex items-center justify-center">
								<p class="font-mono text-xs text-base-content/40 tracking-widest uppercase">[ФОТО 3]</p>
							</div>
							<figcaption class="p-3 text-sm text-base-content/60">[Подпись к фото]</figcaption>
						</figure>
						<figure class="border border-base-content/20 bg-base-200 overflow-hidden">
							<div class="aspect-[4/3] bg-base-300 flex items-center justify-center">
								<p class="font-mono text-xs text-base-content/40 tracking-widest uppercase">[ФОТО 4]</p>
							</div>
							<figcaption class="p-3 text-sm text-base-content/60">[Подпись к фото]</figcaption>
						</figure>
						<figure class="border border-base-content/20 bg-base-200 overflow-hidden">
							<div class="aspect-[4/3] bg-base-300 flex items-center justify-center">
								<p class="font-mono text-xs text-base-content/40 tracking-widest uppercase">[ФОТО 5]</p>
							</div>
							<figcaption class="p-3 text-sm text-base-content/60">[Подпись к фото]</figcaption>
						</figure>
						<figure class="border border-base-content/20 bg-base-200 overflow-hidden">
							<div class="aspect-[4/3] bg-base-300 flex items-center justify-center">
								<p class="font-mono text-xs text-base-content/40 tracking-widest uppercase">[ФОТО 6]</p>
							</div>
							<figcaption class="p-3 text-sm text-base-content/60">[Подпись к фото]</figcaption>
						</figure>
					</div>
				</div>
			</section>

			<!-- ═══ 8. КАРТА ═══ -->
			<section id="map" class="border-b border-base-content/20 bg-base-200 px-4 py-16 md:px-8 md:py-20">
				<div class="mx-auto max-w-6xl space-y-8">
					<div>
						<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-2">Где мы находимся</p>
						<h2 class="font-display text-4xl leading-[1.1] md:text-5xl font-bold">Как добраться</h2>
						<p class="mt-3 max-w-2xl text-base-content/70">
							[АДРЕС]. [ОРИЕНТИРЫ].
						</p>
					</div>
					<div class="border border-base-content/20 overflow-hidden bg-base-300" style="height: 400px;">
						<!-- Замени src на ссылку Яндекс.Карт нужного адреса -->
						<iframe
							src="https://yandex.ru/map-widget/v1/?ll=[LON]%2C[LAT]&z=17"
							width="100%"
							height="400"
							frameborder="0"
							allowfullscreen
							title="Яндекс.Карта — {{PROJECT_NAME}}"
							class="block"
						></iframe>
					</div>
				</div>
			</section>

			<!-- ═══ 9. КОНТАКТЫ И ФОРМА ═══ -->
			<section id="booking" class="border-b border-base-content/20 bg-base-100 px-4 py-16 md:px-8 md:py-20">
				<div class="mx-auto max-w-6xl space-y-8">
					<div>
						<h2 class="font-display text-4xl leading-[1.1] md:text-5xl font-bold">Контакты</h2>
						<p class="mt-3 text-base-content/70">
							[ЗАПОЛНИТЬ: адрес, телефон, режим работы]
						</p>
					</div>
					<div class="grid gap-8 md:grid-cols-2">
						<div class="space-y-5">
							<div class="border border-base-content/20 bg-base-200 p-5 space-y-4">
								<div>
									<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-1">АДРЕС</p>
									<p class="text-lg font-semibold">[АДРЕС]</p>
								</div>
								<div>
									<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-1">ТЕЛЕФОН</p>
									<a href="tel:{{PHONE}}" class="text-lg font-semibold text-primary hover:underline">{{PHONE}}</a>
								</div>
								<div>
									<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-1">ЧАСЫ РАБОТЫ</p>
									<p class="text-lg font-semibold">[ЧАСЫ]</p>
								</div>
							</div>
						</div>
						<div class="border border-base-content/20 bg-base-200 p-6">
							<p class="font-mono text-xs uppercase tracking-widest text-base-content/50 mb-4">СВЯЗАТЬСЯ С НАМИ</p>
							<form class="space-y-4">
								<div>
									<label class="block text-sm font-medium mb-1">Имя *</label>
									<input type="text" required class="input w-full border border-base-content/20 bg-base-100 rounded-none" placeholder="Ваше имя" />
								</div>
								<div>
									<label class="block text-sm font-medium mb-1">Телефон *</label>
									<input type="tel" required class="input w-full border border-base-content/20 bg-base-100 rounded-none" placeholder="+7 (___) ___-__-__" />
								</div>
								<div>
									<label class="block text-sm font-medium mb-1">Пожелания</label>
									<textarea class="textarea w-full border border-base-content/20 bg-base-100 rounded-none" rows="3" placeholder="Ваши пожелания..."></textarea>
								</div>
								<label class="flex items-start gap-2 text-xs text-base-content/60">
									<input type="checkbox" required class="mt-0.5" />
									<span>Отправляя форму, я соглашаюсь на обработку контактных данных для связи.</span>
								</label>
								<button type="submit" class="btn btn-primary w-full">Отправить заявку</button>
							</form>
						</div>
					</div>
				</div>
			</section>

		</main>

		<!-- ═══ FOOTER ═══ -->
		<footer class="border-t border-base-content/20 bg-base-300 px-4 py-8 md:px-8">
			<div class="mx-auto max-w-6xl flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-base-content/60">
				<div class="flex items-center gap-4">
					<span class="font-mono text-xs uppercase tracking-widest text-primary">{{PROJECT_NAME}}</span>
					<span>© 2026 {{PROJECT_NAME}}</span>
				</div>
				<div class="flex gap-4">
					<a href="#about" class="hover:text-primary transition-colors">О нас</a>
					<a href="#services" class="hover:text-primary transition-colors">Услуги</a>
					<a href="#booking" class="hover:text-primary transition-colors">Контакты</a>
				</div>
			</div>
		</footer>

	</div>
</Layout>
